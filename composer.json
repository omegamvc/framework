{
  "name": "omegamvc/framework",
  "type": "project",
  "description": "OmegaFramework is a lightweight and modular PHP framework designed for building modern web applications following the MVC architecture. It is optimized for PHP 8+ and provides a simple, extensible foundation for rapid application development.",
  "homepage": "https://omegamvc.github.io",
  "license": "GPL-3.0",
  "authors": [
    {
      "name": "Adriano Giovannini",
      "email": "agisoftt@gmail.com",
      "role": "Developer"
    }
  ],
  "keywords": [
    "omegamvc",
    "framework",
    "php-framework",
    "mvc",
    "web-application",
    "lightweight",
    "php8.2",
    "open-source",
    "modular-framework"
  ],
  "require": {
    "php": ">=8.2",
    "ext-fileinfo": "*",
    "ext-ftp": "*",
    "ext-mbstring": "*",
    "ext-memcached": "*",
    "ext-pdo": "*",
    "ext-zip": "*",
    "symfony/console": "^7.1"
  },
  "require-dev": {
    "filp/whoops": "^2.15",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.4",
    "squizlabs/php_codesniffer": "^3.11"
  },
  "autoload": {
    "psr-4": {
      "Omega\\": "src/"
    },
    "files": [
      "src/Helpers/function.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "suggest": {

  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
